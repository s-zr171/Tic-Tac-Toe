import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import javax.swing.*;

public class TicTacToeGUI {
    public static char[][] board = new char[3][3];
    public static char currentPlayer = 'X';
    public static boolean gameOver = false;
    public static JButton[][] buttons = new JButton[3][3]; // Buttons for GUI
    public static JLabel statusLabel = new JLabel("Player X's turn");
    public static JLabel scoreLabel = new JLabel("Player X: 0 - Player O: 0");
    public static int scoreX = 0, scoreO = 0;  // Variables to store scores for Player X and Player O

    public static void main(String[] args) {
        // Create the main window (JFrame)
        JFrame frame = new JFrame("Tic-Tac-Toe");
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setSize(400, 500);  // Set the window size, make it taller to accommodate the scoreboard

        // Create a panel for the grid layout
        JPanel panel = new JPanel();
        panel.setLayout(new GridLayout(3, 3)); 

        // Create a title label
        JLabel titleLabel = new JLabel("Tic-Tac-Toe", SwingConstants.CENTER);
        titleLabel.setFont(new Font("Arial", Font.BOLD, 30));
        titleLabel.setForeground(new Color(0, 0, 255));  // Blue color for the title
        titleLabel.setPreferredSize(new Dimension(400, 50)); // Set the size for the title

        // Initialize the game board and buttons
        initializeBoard();
        initializeButtons(panel);

        scoreLabel.setFont(new Font("Arial", Font.PLAIN, 18));
        scoreLabel.setForeground(new Color(0, 0, 0));  
        scoreLabel.setHorizontalAlignment(SwingConstants.CENTER);

        statusLabel.setFont(new Font("Arial", Font.PLAIN, 18));
        statusLabel.setHorizontalAlignment(SwingConstants.CENTER);

        JButton restartButton = new JButton("Restart Game");
        restartButton.setFont(new Font("Arial", Font.PLAIN, 20));
        restartButton.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                restartGame();
            }
        });

        frame.setLayout(new BorderLayout());
        frame.add(titleLabel, BorderLayout.NORTH); 
        frame.add(scoreLabel, BorderLayout.NORTH);  
        frame.add(panel, BorderLayout.CENTER);     
        frame.add(statusLabel, BorderLayout.SOUTH); 
        frame.add(restartButton, BorderLayout.PAGE_END);  

        // Make the window visible
        frame.setVisible(true);
    }

    public static void initializeBoard() {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                board[i][j] = '-';  // Initialize all spots with '-'
            }
        }
    }

    public static void initializeButtons(JPanel panel) {
        // Loop through to create buttons for each cell in the board
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                buttons[i][j] = new JButton("-");
                buttons[i][j].setFont(new Font("Arial", Font.BOLD, 60)); // Large font for X and O
                buttons[i][j].setFocusPainted(false); // Remove focus border
                buttons[i][j].setBackground(new Color(240, 240, 240)); // Light gray
                buttons[i][j].addActionListener(new ButtonClickListener(i, j)); // Add action listener for each button
                panel.add(buttons[i][j]);
            }
        }
    }

    // ActionListener for handling button clicks
    static class ButtonClickListener implements ActionListener {
        int row, col;

        ButtonClickListener(int row, int col) {
            this.row = row;
            this.col = col;
        }

        @Override
        public void actionPerformed(ActionEvent e) {
            if (board[row][col] == '-' && !gameOver) { // Only allow moves in empty spots and when the game is not over
                board[row][col] = currentPlayer;
                buttons[row][col].setText(String.valueOf(currentPlayer));
                checkForWinner();
                switchPlayer();
            }
        }
    }

    public static void switchPlayer() {
        currentPlayer = (currentPlayer == 'X') ? 'O' : 'X';
        statusLabel.setText("Player " + currentPlayer + "'s turn");
    }

    public static void checkForWinner() {
        // Check rows, columns, and diagonals
        if (checkRows() || checkColumns() || checkDiagonals()) {
            updateScore();
            highlightWinningCombination();
            showWinnerDialog("Player " + currentPlayer + " wins!");
            gameOver = true;
        } else if (isBoardFull()) {
            showWinnerDialog("It's a tie!");
            gameOver = true;
        }
    }

    public static boolean checkRows() {
        for (int i = 0; i < 3; i++) {
            if (board[i][0] == currentPlayer && board[i][1] == currentPlayer && board[i][2] == currentPlayer) {
                return true;
            }
        }
        return false;
    }

    public static boolean checkColumns() {
        for (int i = 0; i < 3; i++) {
            if (board[0][i] == currentPlayer && board[1][i] == currentPlayer && board[2][i] == currentPlayer) {
                return true;
            }
        }
        return false;
    }

    public static boolean checkDiagonals() {
        if (board[0][0] == currentPlayer && board[1][1] == currentPlayer && board[2][2] == currentPlayer) {
            return true;
        }
        if (board[0][2] == currentPlayer && board[1][1] == currentPlayer && board[2][0] == currentPlayer) {
            return true;
        }
        return false;
    }

    public static boolean isBoardFull() {
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                if (board[i][j] == '-') {
                    return false;
                }
            }
        }
        return true;
    }

    public static void highlightWinningCombination() {
        // Highlight the winning combination
        for (int i = 0; i < 3; i++) {
            if (board[i][0] == currentPlayer && board[i][1] == currentPlayer && board[i][2] == currentPlayer) {
                buttons[i][0].setBackground(Color.GREEN);
                buttons[i][1].setBackground(Color.GREEN);
                buttons[i][2].setBackground(Color.GREEN);
            }
        }
        for (int i = 0; i < 3; i++) {
            if (board[0][i] == currentPlayer && board[1][i] == currentPlayer && board[2][i] == currentPlayer) {
                buttons[0][i].setBackground(Color.GREEN);
                buttons[1][i].setBackground(Color.GREEN);
                buttons[2][i].setBackground(Color.GREEN);
            }
        }
        if (board[0][0] == currentPlayer && board[1][1] == currentPlayer && board[2][2] == currentPlayer) {
            buttons[0][0].setBackground(Color.GREEN);
            buttons[1][1].setBackground(Color.GREEN);
            buttons[2][2].setBackground(Color.GREEN);
        }
        if (board[0][2] == currentPlayer && board[1][1] == currentPlayer && board[2][0] == currentPlayer) {
            buttons[0][2].setBackground(Color.GREEN);
            buttons[1][1].setBackground(Color.GREEN);
            buttons[2][0].setBackground(Color.GREEN);
        }
    }

    public static void updateScore() {
        if (currentPlayer == 'X') {
            scoreX++;
        } else {
            scoreO++;
        }
        scoreLabel.setText("Player X: " + scoreX + " - Player O: " + scoreO);
    }

    public static void restartGame() {
        gameOver = false;
        currentPlayer = 'X';
        initializeBoard();
        for (int i = 0; i < 3; i++) {
            for (int j = 0; j < 3; j++) {
                buttons[i][j].setText("-");
                buttons[i][j].setBackground(new Color(240, 240, 240)); // Reset background color
                buttons[i][j].setEnabled(true);  // Enable all buttons again
            }
        }
        statusLabel.setText("Player X's turn");
    }

    public static void showWinnerDialog(String message) {
        // Show winner dialog
        JOptionPane.showMessageDialog(null, message, "Game Over", JOptionPane.INFORMATION_MESSAGE);
    }
}

